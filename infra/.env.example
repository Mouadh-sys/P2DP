# Copy to infra/.env and adjust for local development.

# PostgreSQL
POSTGRES_DB=p2dp
POSTGRES_USER=p2dp
POSTGRES_PASSWORD=p2dp

# Application
ENVIRONMENT=dev
SECRET_KEY=change-me-in-production

# MinIO
MINIO_ACCESS_KEY=p2dp
MINIO_SECRET_KEY=p2dp12345
MINIO_BUCKET=p2dp-artifacts

# GitOps (optional remote push)
GITOPS_REMOTE_URL=
GITHUB_TOKEN=
GITOPS_GIT_USER=p2dp-bot
GITOPS_GIT_EMAIL=p2dp-bot@local

# Argo CD (optional; typically from a local k3d/kind cluster)
ARGOCD_SERVER=
ARGOCD_TOKEN=
ARGOCD_APP_NAME=p2dp-dev

# Kubernetes (optional; point kubectl at your local cluster)
KUBECTL_CONTEXT=
K8S_NAMESPACE_PREFIX=p2dp

# Layer 4 simulated log directory (Compose mounts ../samples at /samples/logs by default)
# SIMULATED_LOGS_PATH=/samples/logs

# Frontend (browser must reach the API host)
VITE_API_BASE_URL=http://localhost:8000
# Jaeger UI base URL for "Open in Jaeger" links from the dashboard
VITE_JAEGER_UI_URL=http://localhost:16686

# OpenTelemetry (API + worker → collector → Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
